generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(User)
  createdAt DateTime @default(now())

  groupsOwned Group[] @relation("GroupOwner")
  memberships GroupMember[]
  tasksAssigned Task[] @relation("TaskAssignee")
  messages Message[]
  directThreadsA DirectThread[] @relation("DirectThreadUserA")
  directThreadsB DirectThread[] @relation("DirectThreadUserB")
  directMessagesSent DirectMessage[] @relation("DirectMessageSender")
  taskComments TaskComment[]
}

model Group {
  id        String   @id @default(uuid())
  name      String
  groupCode String   @unique
  ownerId   String
  coverImage String?
  createdAt DateTime @default(now())

  owner     User @relation("GroupOwner", fields: [ownerId], references: [id])

  members   GroupMember[]
  tasks     Task[]
  lists     List[]
  labels    Label[]
  messages  Message[]
}

model GroupMember {
  id        String @id @default(uuid())
  userId    String
  groupId   String
  role      String

  user   User  @relation(fields: [userId], references: [id])
  group  Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId]) 
}
model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  position    Int        @default(0)
  groupId     String
  listId      String
  assignedTo  String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id])
  list     List  @relation(fields: [listId], references: [id])
  assignee User? @relation("TaskAssignee", fields: [assignedTo], references: [id])
  taskLabels TaskLabel[]
  checklistItems ChecklistItem[]
  comments TaskComment[]

  @@index([listId, position])
}


model TaskComment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  senderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([taskId, createdAt])
  @@index([senderId])
}

model List {
  id        String   @id @default(uuid())
  name      String
  position  Int      @default(0)
  groupId   String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  tasks Task[]

  @@index([groupId, position])
}

model Label {
  id        String   @id @default(uuid())
  name      String
  color     String
  groupId   String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  taskLabels TaskLabel[]

  @@index([groupId])
}

model TaskLabel {
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model ChecklistItem {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  taskId      String
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])

  @@index([taskId, position])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  groupId   String
  senderId  String
  createdAt DateTime @default(now())

  group  Group @relation(fields: [groupId], references: [id])
  sender User  @relation(fields: [senderId], references: [id])
}

model DirectThread {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA    User            @relation("DirectThreadUserA", fields: [userAId], references: [id])
  userB    User            @relation("DirectThreadUserB", fields: [userBId], references: [id])
  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DirectMessage {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  thread DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User         @relation("DirectMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@index([senderId])
}

enum Role{
  User
  Admin
}