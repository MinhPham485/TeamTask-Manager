generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(User)
  createdAt DateTime @default(now())

  phone     String?
  hometown  String?
  bio       String?
  avatarUrl String?

  passwordResetCodeHash   String?
  passwordResetExpiresAt  DateTime?
  passwordResetAttempts   Int       @default(0)
  passwordResetResendAt   DateTime?
  passwordResetConsumedAt DateTime?

  groupsOwned             Group[]              @relation("GroupOwner")
  memberships             GroupMember[]
  tasksAssigned           Task[]               @relation("TaskAssignee")
  tasksCreated            Task[]               @relation("TaskCreator")
  messages                Message[]
  directThreadsA          DirectThread[]       @relation("DirectThreadUserA")
  directThreadsB          DirectThread[]       @relation("DirectThreadUserB")
  directMessagesSent      DirectMessage[]      @relation("DirectMessageSender")
  taskComments            TaskComment[]
  attachments             Attachment[]
  taskMemberships         TaskMember[]
  deadlineTasksCreated    DeadlineTask[]       @relation("DeadlineTaskCreator")
  deadlineTaskMemberships DeadlineTaskMember[]
  notifications           Notification[]       @relation("NotificationRecipient")
  notificationsAuthored   Notification[]       @relation("NotificationActor")
}

model Group {
  id         String   @id @default(uuid())
  name       String
  groupCode  String   @unique
  ownerId    String
  coverImage String?
  createdAt  DateTime @default(now())

  owner User @relation("GroupOwner", fields: [ownerId], references: [id])

  members       GroupMember[]
  tasks         Task[]
  lists         List[]
  labels        Label[]
  messages      Message[]
  deadlineTasks DeadlineTask[]
}

model GroupMember {
  id      String @id @default(uuid())
  userId  String
  groupId String
  role    String

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  position    Int       @default(0)
  groupId     String
  listId      String
  assignedTo  String?
  createdBy   String?
  dueDate     DateTime?
  progress    Int       @default(0)
  priority    String    @default("Low")
  createdAt   DateTime  @default(now())

  group             Group              @relation(fields: [groupId], references: [id])
  list              List               @relation(fields: [listId], references: [id])
  assignee          User?              @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator           User?              @relation("TaskCreator", fields: [createdBy], references: [id])
  taskLabels        TaskLabel[]
  taskMemberships   TaskMember[]
  checklistSections ChecklistSection[]
  checklistItems    ChecklistItem[]
  comments          TaskComment[]
  attachments       Attachment[]

  @@index([listId, position])
}

model TaskMember {
  id          String         @id @default(uuid())
  taskId      String
  userId      String
  role        TaskMemberRole @default(member)
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model DeadlineTask {
  id          String    @id @default(uuid())
  title       String
  description String?
  groupId     String
  createdBy   String?
  dueDate     DateTime?
  progress    Int       @default(0)
  priority    String    @default("Low")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  group          Group                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator        User?                   @relation("DeadlineTaskCreator", fields: [createdBy], references: [id])
  memberships    DeadlineTaskMember[]
  checklistSections DeadlineChecklistSection[]
  checklistItems DeadlineChecklistItem[]
  notifications Notification[]

  @@index([groupId, dueDate])
  @@index([createdBy])
}

model Notification {
  id             String    @id @default(uuid())
  userId         String
  actorId        String?
  type           String
  title          String
  body           String
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  readAt         DateTime?
  deadlineTaskId String?
  groupId        String?

  user         User          @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor        User?         @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  deadlineTask DeadlineTask? @relation(fields: [deadlineTaskId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([deadlineTaskId])
  @@index([groupId])
  @@index([actorId])
}

model DeadlineTaskMember {
  id             String         @id @default(uuid())
  deadlineTaskId String
  userId         String
  role           TaskMemberRole @default(member)
  completedAt    DateTime?
  createdAt      DateTime       @default(now())

  deadlineTask DeadlineTask @relation(fields: [deadlineTaskId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deadlineTaskId, userId])
  @@index([deadlineTaskId])
  @@index([userId])
}

model DeadlineChecklistItem {
  id             String   @id @default(uuid())
  deadlineTaskId String
  sectionId      String
  title          String
  isCompleted    Boolean  @default(false)
  position       Int      @default(0)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deadlineTask DeadlineTask @relation(fields: [deadlineTaskId], references: [id], onDelete: Cascade)
  section      DeadlineChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([deadlineTaskId, position])
  @@index([sectionId, position])
}

model DeadlineChecklistSection {
  id             String   @id @default(uuid())
  title          String
  position       Int      @default(0)
  deadlineTaskId String
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deadlineTask DeadlineTask            @relation(fields: [deadlineTaskId], references: [id], onDelete: Cascade)
  items        DeadlineChecklistItem[]

  @@index([deadlineTaskId, position])
}

model TaskComment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  senderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([taskId, createdAt])
  @@index([senderId])
}

model List {
  id        String   @id @default(uuid())
  name      String
  position  Int      @default(0)
  groupId   String
  createdAt DateTime @default(now())

  group Group  @relation(fields: [groupId], references: [id])
  tasks Task[]

  @@index([groupId, position])
}

model Label {
  id        String   @id @default(uuid())
  name      String
  color     String
  groupId   String
  createdAt DateTime @default(now())

  group      Group       @relation(fields: [groupId], references: [id])
  taskLabels TaskLabel[]

  @@index([groupId])
}

model TaskLabel {
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model ChecklistSection {
  id        String   @id @default(uuid())
  title     String
  position  Int      @default(0)
  taskId    String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task  Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([taskId, position])
}

model ChecklistItem {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  taskId      String
  sectionId   String
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task    Task             @relation(fields: [taskId], references: [id])
  section ChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
  @@index([sectionId, position])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  groupId   String
  senderId  String
  createdAt DateTime @default(now())

  group       Group        @relation(fields: [groupId], references: [id])
  sender      User         @relation(fields: [senderId], references: [id])
  attachments Attachment[]
}

model Attachment {
  id         String   @id @default(uuid())
  fileName   String
  mimeType   String
  size       Int
  url        String
  key        String
  taskId     String?
  messageId  String?
  uploaderId String
  createdAt  DateTime @default(now())

  task     Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id])

  @@index([taskId])
  @@index([messageId])
  @@index([uploaderId])
}

model DirectThread {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA    User            @relation("DirectThreadUserA", fields: [userAId], references: [id])
  userB    User            @relation("DirectThreadUserB", fields: [userBId], references: [id])
  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model DirectMessage {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  thread DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User         @relation("DirectMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@index([senderId])
}

enum Role {
  User
  Admin
}

enum TaskMemberRole {
  leader
  member
}
