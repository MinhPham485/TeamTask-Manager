# Copy to .env.docker (or export these in shell) when running docker compose
POSTGRES_DB=teamtask
POSTGRES_USER=teamtask
POSTGRES_PASSWORD=teamtaskpw
DATABASE_URL=postgresql://teamtask:teamtaskpw@db:5432/teamtask?schema=public
JWT_SECRET=change-me-in-real-usage
DOCKER_BACKEND_PORT=5001

# AI Assistant (backend-only secrets)
AI_FEATURE_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_ALLOW_MOCK_WHEN_NO_KEY=false
AI_REQUEST_TIMEOUT_MS=30000
AI_RETRY_COUNT=1
AI_MAX_QUESTION_CHARS=800
AI_RATE_LIMIT_PER_MINUTE=20
